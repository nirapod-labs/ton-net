# Normalize to LF in the repository whatever a checkout uses locally.
* text=auto eol=lf

# Test fixtures are blocks and proofs captured from mainnet, compared byte for
# byte. Marking them generated keeps them out of language statistics and collapses
# them in a diff, where a wall of hex hides the change that matters.
*.hex linguist-generated=true -diff
crates/ton-net/src/mainnet.config.json linguist-generated=true

# Lockfiles are resolved output. A conflict in one is settled by re-resolving.
Cargo.lock linguist-generated=true
package-lock.json linguist-generated=true

# The third-party notices are generated from the dependency graph by
# `just licenses`. A dependency bump moves 145 kB of other people's license text,
# and the change worth reading is which crates moved, not the boilerplate.
THIRD-PARTY-LICENSES.md linguist-generated=true

# The spikes are committed evidence for decisions already taken, not the library.
spikes/** linguist-vendored=true
