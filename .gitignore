target/
.DS_Store
node_modules/
*.node

# `release-plz generate-schema` writes the configuration schema here. It is a
# reference for editing release-plz.toml, not part of the project.
.schema/

# cargo-mutants writes its report here. The finding belongs in a test or in the
# exclusions, not in the repository.
mutants.out/
mutants.out.old/

# napi-rs generates the loader and the type definitions from the Rust binding, and
# both are tracked. The definitions are the published TypeScript API and the doc
# comments a caller reads in an editor, so leaving them untracked would put the
# whole JavaScript surface outside review. CI regenerates and fails on a diff.

# What the resume examples persist. The whole point of that example is that the file
# is the next run's root of trust, so committing one would be committing a trust
# anchor nobody chose.
anchor.txt
anchor.json

# The license, the notice and the third-party notices are copied into every
# publishable package before the tarball is built, because Apache-2.0 requires a
# redistribution to carry them and an npm consumer never sees the repository root.
# The originals live there; these are copies, and the third one is 145 kB, so
# tracking eight of it would put a megabyte of duplication in every clone.
bindings/node/LICENSE
bindings/node/NOTICE
bindings/node/THIRD-PARTY-LICENSES.md
bindings/node/npm/*/LICENSE
bindings/node/npm/*/NOTICE
bindings/node/npm/*/THIRD-PARTY-LICENSES.md
